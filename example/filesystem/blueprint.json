{
    "cleanup":{
        "clean-all-build-data":{
            "module":"filesystem.cleanup",
            "args":{
                "folders":[
                    "binaries",
                    "dist",
                    "build",
                    "obj",
                    "example",
                    "example_copy"
                ],
                "files":[
                    "my_file.json",
                    "my_file.yaml"
                ]
            }
        }
    },
    "copy":{
        "copy-files":{
            "module":"filesystem.copy",
            "args":{
                "source":"example",
                "destination":"example_copy"
            }
        }
    }
}
