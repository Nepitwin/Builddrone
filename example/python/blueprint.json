{
    "build": [
        {
            "module": "python.venv",
            "args": {
                "source": ".venv"
            }
        },
        {
            "module": "python.install",
            "args": {
                "requirements": "requirements.txt"
            }
        },
        {
            "module": "python.pylint",
            "args": {
                "paths": ["."],
                "ignore": [".venv"]
            }
        },
        {
            "module": "python.pylint",
            "args": {
                "files": ["main.py"]
            }
        }
    ]
}
