{
    "test": [
        {
            "module": "python.venv",
            "args": {
                "source": ".venv"
            }
        },
        {
            "module": "python.install",
            "args": {
                "requirements": "requirements.txt"
            }
        },
        {
            "module": "robotframework.test",
            "args": {
                "arguments": {
                    "--outputdir": "results",
                    "tests": null
                }
            }
        },
        {
            "module": "robotframework.rebot",
            "args": {
                "arguments": {
                    "--outputdir": "results/rebot",
                    "--name": "Builddrone Robot Example",
                    "results/output.xml": null
                }
            }
        }
    ],
    "cleanup": [
        {
            "module": "filesystem.cleanup",
            "args": {
                "folders": [
                    ".venv",
                    "results"
                ]
            }
        }
    ]
}
